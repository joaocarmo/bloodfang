{
  "name": "@bloodfang/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p e2e/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src/",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile --typescript",
    "i18n:check": "lingui extract --clean && git diff --exit-code -- 'src/locales/**/*.po'",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@bloodfang/engine": "workspace:*",
    "@floating-ui/react": "^0.27.19",
    "@lingui/core": "^5.9.2",
    "@lingui/react": "^5.9.2",
    "@tanstack/react-router": "^1.163.2",
    "motion": "^12.34.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@bloodfang/server": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@lingui/babel-plugin-lingui-macro": "^5.9.2",
    "@lingui/cli": "^5.9.2",
    "@lingui/vite-plugin": "^5.9.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.0",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "tailwindcss": "^4.2.0",
    "vite": "^7.3.1",
    "vite-plugin-image-optimizer": "^2.0.3",
    "ws": "^8.19.0"
  }
}
