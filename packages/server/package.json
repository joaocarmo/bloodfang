{
  "name": "@bloodfang/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./protocol": {
      "types": "./dist/protocol.d.mts",
      "import": "./dist/protocol.mjs"
    },
    "./testing": {
      "types": "./dist/testing.d.mts",
      "import": "./dist/testing.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx --watch --env-file=../../.env.dev src/index.ts",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@bloodfang/engine": "workspace:*",
    "@hono/node-server": "^1.14.3",
    "@hono/node-ws": "^1.1.1",
    "hono": "^4.7.11",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.3",
    "tsdown": "^0.21.3",
    "tsx": "^4.19.4",
    "typescript-eslint": "^8.57.0",
    "ws": "^8.18.2"
  }
}
