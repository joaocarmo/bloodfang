{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!pnpm-lock.yaml",
      "!packages/client/src/locales"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedFunctionParameters": "error"
      },
      "style": {
        "useForOf": "error",
        "useShorthandFunctionType": "error",
        "noInferrableTypes": "error",
        "useConsistentArrayType": "error"
      },
      "complexity": {
        "noStaticOnlyClass": "error",
        "useLiteralKeys": "off"
      },
      "suspicious": {
        "noEmptyBlockStatements": "error"
      }
    }
  }
}
